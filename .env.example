# MongoDB
# Get your MongoDB connection string from MongoDB Atlas
MONGODB_URI=your-mongodb-connection-string-here

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-jwt-secret-here

# NextAuth Secret (optional, for additional auth features)
NEXTAUTH_SECRET=your-nextauth-secret-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────
# AI API Configuration
# API: api.aisubscription.shop
# ─────────────────────────────────────────────────────

# AI API Key (Required for AI features)
AI_API_KEY=your-ai-api-key-here

# AI Model (default: google/gemini-2.5-flash)
# Available models:
#   - google/gemini-2.5-flash-lite
#   - google/gemini-2.5-flash
#   - google/gemini-3.1-flash-lite-preview
#   - google/gemini-2.5-pro
#   - google/gemini-3.1-pro-preview
#   - Qwen/Qwen3.6-27B
#   - minimax-m2.5-thinking
#   - ibnzterrell/Meta-Llama-3.3-70B-Instruct-AWQ-INT4
AI_MODEL=google/gemini-2.5-flash
