# MongoDB
# Get your MongoDB connection string from MongoDB Atlas
MONGODB_URI=your-mongodb-connection-string-here

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-jwt-secret-here

# NextAuth Secret (optional, for additional auth features)
NEXTAUTH_SECRET=your-nextauth-secret-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────
# OpenRouter AI Configuration
# Get your API key from: https://openrouter.ai/keys
# ─────────────────────────────────────────────────────

# OpenRouter API Key (Required for AI features)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# AI Model to use (default: openrouter/owl-alpha)
# Other options: anthropic/claude-3.5-sonnet, openai/gpt-4, etc.
# See all models at: https://openrouter.ai/models
AI_MODEL=openrouter/owl-alpha

# Site Configuration (Optional - for OpenRouter rankings)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Comicore
