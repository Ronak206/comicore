# ─── COMICORE Environment Variables ───
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── MongoDB Atlas ─────────────────────────────────
# Required. Connection string for your MongoDB Atlas cluster.
# Get it from: Atlas → Connect → Drivers → Connection string (SRV)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── AI Worker (Cloudflare) ───────────────────────
# Optional. URL of your deployed Cloudflare Worker for AI model routing.
# Falls back to https://comicore.robin241205.workers.dev if not set.
# Endpoints: /write (Claude), /think (Claude Thinking), /memory (Gemini), /generate (Pipeline)
AI_WORKER_URL=https://comicore.robin241205.workers.dev
